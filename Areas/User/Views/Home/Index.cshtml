<!-- SẢN PHẨM MỚI -->
<!-- SẢN PHẨM MỚI (slider 10 sp, desktop 4 sp/khung) -->
<section class="sec">
    <div class="container">
        <div class="sec-head">
            <h2>SẢN PHẨM MỚI</h2>
            <div class="seperate-icon">
                <img loading="lazy" width="117" height="7" src="https://web.static.nvncdn.com/tp/T0295/img/underline-ic.png?v=9">
            </div>
            <a href="/product">Xem thêm</a>
        </div>

        <div class="new-products-wrapper">
            <!-- Nút Prev -->
            <button class="np-nav np-prev" type="button">
                <i class="bi bi-chevron-left"></i>
            </button>

            <div class="owl-carousel owl-theme" id="newProducts">
                @foreach (var item in lstSPNew)
                {
                    var isSaleOff = item.PriceDiscount.HasValue && item.PriceDiscount > 0;

                    <div class="item">
                        <a href="@($"/{SlugHelper.GenerateSlug(item.Name)}-p{item.Id}")" class="p-card d-block">
                            @if (item.CountInStock <= 0)
                            {
                                <span class="badge-stock">HẾT HÀNG</span>
                            }
                            @if (isSaleOff)
                            {
                                var salePercent = 100 - (int)((item.PriceDiscount.Value / item.Price) * 100);
                                <span class="badge-sale"><span class="sale-percent">@(salePercent)</span>% off</span>
                            }
                            <img class="p-img" src="@item.ImageUrl.FirstOrDefault()" alt="@item.Name">
                            <div class="p-name">@item.Name</div>
                            @if (isSaleOff)
                            {
                                <div class="p-price"><span class="p-old">@item.Price.ToStringNumber() ₫</span>@item.PriceDiscount.ToStringNumber() ₫</div>
                            }
                            else
                            {
                                <div class="p-price">@item.Price.ToStringNumber() ₫</div>
                            }
                        </a>
                    </div>
                }
            </div>

            <!-- Nút Next -->
            <button class="np-nav np-next" type="button">
                <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    </div>
</section>

<!-- SẢN PHẨM BÁN CHẠY (layout giống ảnh: 2 cột trái grid + 1 ảnh lớn phải) -->
