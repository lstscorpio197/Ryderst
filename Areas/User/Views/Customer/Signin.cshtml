@{
    ViewBag.Title = "Đăng nhập";
}

<link rel="stylesheet" href="~/css/Shop/customer.css" />
<div class="row signin-container">
    <div class="col-md-8 col-sm-0 signin-left-container">
        <img src="/Images/banner.jpg" />
    </div>
    <div class="col-md-4 col-sm-12 signin-right-container">
        <form id="signin-form" action="/signin" method="post">

            <div class="signin-title">
                <span class="">Đăng nhập</span>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.Message))
            {
                <div class="">
                    <div class="">
                        <label class="custom-control-label error">@ViewBag.Message</label>
                    </div>
                </div>
            }

            <div class="input-group mb-3">
                <div class="input-group-append">
                    <span class="input-group-text"><i class="fas fa-user"></i></span>
                </div>
                <input type="text" name="username" class="form-control input_user" value="" placeholder="Số điện thoại hoặc email" required>
            </div>
            <div class="input-group mb-2">
                <div class="input-group-append">
                    <span class="input-group-text"><i class="fas fa-key"></i></span>
                </div>
                <input type="password" name="password" class="form-control input_pass" value="" placeholder="Mật khẩu" required>
            </div>
            <div class="d-flex justify-content-center mt-3 login_container">
                <button type="submit" name="button" class="btn btn-signin">Đăng nhập</button>
            </div>

            <div>
                <div class="d-flex justify-content-center mt-4">
                    <a href="/getpassword">Quên mật khẩu</a>
                </div>
                <div class="d-flex justify-content-center mt-3">
                    <a href="/signup">Đăng ký tài khoản mới</a>
                </div>
            </div>
        </form>
    </div>
</div>