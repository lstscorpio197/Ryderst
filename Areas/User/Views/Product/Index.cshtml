@using ShopAdmin.Common
@using ShopAdmin.Dto.Products
@using ShopAdmin.Helper

@model List<ProductDto>
@{
    decimal maxprice = ViewBag.Maxprice ?? 2000000;
    string search = ViewBag.Search ?? "";
    string sort = ViewBag.Sort ?? "default";
    var items = Model ?? new List<ProductDto>();
}
<link rel="stylesheet" href="~/css/Shop/home.css" />
<style>
    .page-head{
      padding: 28px 0 18px;
      border-bottom: 1px solid var(--line);
      margin-bottom: 22px;
    }

    .page-title{
      font-weight: 600;
      letter-spacing: .06em;
      text-transform: uppercase;
      font-size: 16px;
      margin: 0;
    }

    .toolbar{
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 16px;
      margin-bottom: 24px;
    }

    .search-box{
      position: relative;
    }

    .search-box i{
      position: absolute;
      left: 14px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
    }

    .search-box input{
      padding-left: 40px;
      height: 46px;
      border-radius: 12px;
      border: 1px solid var(--line);
    }

    .form-select, .form-range, .form-control{
      box-shadow: none !important;
    }

    .form-select{
      height: 46px;
      border-radius: 12px;
      border: 1px solid var(--line);
    }

    .price-box{
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 10px 14px;
      background: var(--soft);
      height: 46px;
      display:flex;
      align-items:center;
      font-weight: 700;
    }

</style>
<div class="container">
    @* <div class="page-head">
        <h1 class="page-title">Sản phẩm</h1>
    </div>
 *@
    <!-- Toolbar -->
    <div class="toolbar">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-lg-5">
                <label class="form-label fw-bold">Tìm kiếm</label>
                <div class="search-box">
                    <i class="bi bi-search"></i>
                    <input id="searchInput" type="text" class="form-control" placeholder="Nhập tên sản phẩm..." value="@search">
                </div>
            </div>

            <div class="col-12 col-md-6 col-lg-4">
                <label class="form-label fw-bold">Khoảng giá tối đa</label>
                <input id="priceRange" type="range" class="form-range" min="10000" max="2000000" step="10000" value="@maxprice">
                <div class="price-box" id="priceValue">Tối đa: @maxprice.ToStringNumber() ₫</div>
            </div>

            <div class="col-12 col-md-6 col-lg-3">
                <label class="form-label fw-bold">Sắp xếp</label>
                <select id="sortSelect" class="form-select">
                    <!option value="default" @(sort == "default" ? "selected" : "")>Mặc định</!option>
                    <!option value="price-asc" @(sort == "price-asc" ? "selected" : "")>Giá tăng dần</!option>
                    <!option value="price-desc" @(sort == "price-desc" ? "selected" : "")>Giá giảm dần</!option>
                    <!option value="name-asc" @(sort == "name-asc" ? "selected" : "")>Tên A → Z</!option>
                    <!option value="name-desc" @(sort == "name-desc" ? "selected" : "")>Tên Z → A</!option>
                </select>
            </div>
        </div>
    </div>


    <div class="row g-4" id="productGrid">
        @foreach (var item in items)
        {
            var isSaleOff = item.PriceDiscount.HasValue && item.PriceDiscount > 0;
            <div class="col-6 col-lg-3">
                <a href="@($"/{SlugHelper.GenerateSlug(item.Name)}-p{item.Id}")" class="p-card d-block">
                    @if(item.CountInStock <= 0)
                    {
                        <span class="badge-stock">HẾT HÀNG</span>
                    }
                    @if (isSaleOff)
                    {
                        var salePercent = 100 - (int)((item.PriceDiscount.Value / item.Price) * 100);
                        <span class="badge-sale"><span class="sale-percent">@(salePercent)</span>% off</span>
                    }
                    <div class="pos-relative">
                        <img class="p-img" src="@item.ImageUrl.FirstOrDefault()" alt="@item.Name">
                    </div>
                    <div class="p-name">@item.Name</div>
                    @if (isSaleOff)
                    {
                        <div class="p-price"><span class="p-old">@item.Price.ToStringNumber() ₫</span>@item.PriceDiscount.ToStringNumber() ₫</div>
                    }
                    else
                    {
                        <div class="p-price">@item.Price.ToStringNumber() ₫</div>
                    }
                </a>
            </div>
        }
    </div>
</div>

@section scripts {
    <script src="/js/Shop/product.js"></script>
}